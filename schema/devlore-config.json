{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noblefactor.com/schemas/devlore-config.json",
  "title": "Devlore Configuration",
  "description": "Shared configuration schema for the devlore ecosystem (lore and writ)",
  "type": "object",
  "properties": {
    "verbosity": {
      "type": "string",
      "enum": ["quiet", "normal", "verbose"],
      "description": "Output verbosity level (shared across lore and writ)",
      "default": "normal"
    },
    "dry_run": {
      "type": "boolean",
      "description": "Show what would be done without making changes (shared across lore and writ)",
      "default": false
    },
    "model": {
      "type": "object",
      "description": "Shared AI/LLM provider configuration (used by both lore and writ)",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["ollama", "anthropic", "openai", "github", "groq", "gemini"],
          "description": "AI provider backend",
          "default": "ollama"
        },
        "name": {
          "type": "string",
          "description": "Model identifier (e.g., 'llama3.1:8b', 'claude-sonnet-4-20250514')",
          "default": "llama3.1:8b"
        },
        "endpoint": {
          "type": "string",
          "format": "uri",
          "description": "Custom endpoint URL (for custom providers)"
        },
        "api_key": {
          "type": "string",
          "description": "API key (prefer native keystore over config file)"
        }
      }
    },
    "registry": {
      "type": "object",
      "description": "Shared package registry configuration (used by both lore and writ)",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Registry repository URL",
          "default": "https://github.com/NobleFactor/devlore-registry.git"
        },
        "branch": {
          "type": "string",
          "description": "Git branch to use",
          "default": "develop"
        },
        "force_tags": {
          "type": "boolean",
          "description": "Force tag resolution even on non-main branches",
          "default": false
        }
      }
    },
    "secrets": {
      "type": "object",
      "description": "Shared secrets configuration for age-encrypted files (ADR-050)",
      "properties": {
        "identity_file": {
          "type": "string",
          "description": "Path to age identity file or SSH private key for decryption"
        },
        "identity_command": {
          "type": "string",
          "description": "Command to fetch identity from external source (e.g., '1password', 'vault')"
        },
        "recipients_file": {
          "type": "string",
          "description": "Recipients file location (relative to target root)",
          "default": ".age-recipients"
        },
        "mode": {
          "type": "string",
          "description": "File permissions for decrypted secrets",
          "default": "0600"
        },
        "on_error": {
          "type": "string",
          "description": "Behavior on decryption failure",
          "enum": ["error", "warn", "skip"],
          "default": "error"
        }
      }
    },
    "lore": {
      "type": "object",
      "description": "Lore-specific configuration (verbosity and dry_run are shared at root level)",
      "properties": {
        "preferences": {
          "type": "object",
          "description": "User preferences for lore operations",
          "properties": {
            "shell": {
              "type": "string",
              "description": "Preferred shell"
            },
            "editor": {
              "type": "string",
              "description": "Preferred editor"
            },
            "pager": {
              "type": "string",
              "description": "Preferred pager"
            },
            "auto_confirm": {
              "type": "boolean",
              "description": "Skip confirmation prompts",
              "default": false
            },
            "color_output": {
              "type": "boolean",
              "description": "Enable colored output",
              "default": true
            },
            "install_path": {
              "type": "string",
              "description": "Default installation path"
            },
            "backup_path": {
              "type": "string",
              "description": "Backup directory for replaced files"
            },
            "max_backups": {
              "type": "integer",
              "description": "Maximum number of backups to keep",
              "default": 5
            },
            "symlink_strategy": {
              "type": "string",
              "enum": ["prefer", "avoid", "always"],
              "description": "Symlink creation strategy",
              "default": "prefer"
            },
            "conflict_policy": {
              "type": "string",
              "enum": ["backup", "overwrite", "skip", "ask"],
              "description": "How to handle file conflicts",
              "default": "ask"
            },
            "enable_hooks": {
              "type": "boolean",
              "description": "Enable pre/post hooks",
              "default": true
            },
            "hooks_timeout": {
              "type": "integer",
              "description": "Hook execution timeout in seconds",
              "default": 300
            }
          }
        },
        "sources": {
          "type": "object",
          "description": "Documentation source configuration",
          "properties": {
            "corporate": {
              "type": "array",
              "description": "Organization-specific documentation sources (highest priority)",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "url": {"type": "string", "format": "uri"},
                  "priority": {"type": "integer"},
                  "enabled": {"type": "boolean", "default": true}
                },
                "required": ["name", "url"]
              }
            }
          }
        }
      }
    },
    "writ": {
      "type": "object",
      "description": "Writ-specific configuration (verbosity and dry_run are shared at root level). Layers are directories at ~/.local/share/devlore/writ/layers/",
      "properties": {
        "segments": {
          "type": "array",
          "description": "Custom segment names (beyond built-in OS, DISTRO, ARCH)",
          "items": {
            "type": "string",
            "description": "Segment name in UPPERCASE (e.g., ROLE, SITE)"
          },
          "examples": [["ROLE", "SITE"]]
        },
        "vars": {
          "type": "object",
          "description": "Template variables and segment value overrides",
          "properties": {
            "USER_NAME": {
              "type": "string",
              "description": "User's full name for git config and other templates"
            },
            "USER_EMAIL": {
              "type": "string",
              "description": "User's email address for git config and other templates"
            },
            "EDITOR": {
              "type": "string",
              "description": "Preferred editor path"
            }
          },
          "additionalProperties": {
            "type": "string",
            "description": "Custom template variable or segment value override"
          }
        }
      }
    }
  }
}
