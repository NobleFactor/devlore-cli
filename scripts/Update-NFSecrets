#!/usr/bin/env bash

# SPDX-License-Identifier: SSPL-1.0
# Copyright (c) 2025-2026 Noble Factor. All rights reserved.

# Update-NFSecrets - Rotate NobleFactor organization secrets

# shellcheck disable=SC1091,SC2154
source "$(dirname "$0")/Declare-BashScript" "$0" "help,no-browser" "h" "$@"

command -v gh >/dev/null 2>&1 || error $EX_UNAVAILABLE "The 'gh' command is required. Install: https://cli.github.com"
command -v curl >/dev/null 2>&1 || error $EX_UNAVAILABLE "The 'curl' command is required."
gh auth status >/dev/null 2>&1 || error $EX_CONFIG "Not authenticated with gh. Run: gh auth login"

###########
# Variables
###########

declare -r org="NobleFactor"
declare -r pat_url="https://github.com/settings/personal-access-tokens/new"

# Secrets to manage
declare -r automation_secret="NOBLEFACTOR_AUTOMATION"
declare -r content_secret="NOBLEFACTOR_CONTENT_ACCESS"

# Repos for validation
declare -r site_repo="NobleFactor/devlore.noblefactor.com"
declare -r registry_repo="NobleFactor/devlore-registry"
declare -r ops_repo="NobleFactor/noblefactor-ops"

###########
# Arguments
###########

declare -r synopsis="Update-NFSecrets [--no-browser]"
eval set -- "$script_arguments"

no_browser=false

while :; do
    case "$1" in
        -h | --help)
            usage "$synopsis"
            ;;
        --no-browser)
            no_browser=true
            shift 1
            ;;
        --)
            shift 1
            break
            ;;
        *)
            break
            ;;
    esac
done

###########
# Functions
###########

validate_token() {
    local token="$1"
    local repo="$2"
    local expected_access="$3"  # "read" or "write"

    local http_code
    http_code=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: Bearer $token" \
        -H "Accept: application/vnd.github+json" \
        "https://api.github.com/repos/$repo")

    case "$http_code" in
        200) return 0 ;;
        401) error $EX_NOPERM "Token is invalid (401 Unauthorized)" ;;
        403) error $EX_NOPERM "Token lacks access to $repo (403 Forbidden)" ;;
        404) error $EX_NOPERM "Token cannot see $repo (404 — check repository permissions)" ;;
        *) error $EX_PROTOCOL "Unexpected response for $repo: HTTP $http_code" ;;
    esac
}

prompt_token() {
    local name="$1"
    local var_name="$2"

    # Check environment variable first
    local env_value="${!var_name}"
    if [[ -n "$env_value" ]]; then
        echo "$env_value"
        return 0
    fi

    # Prompt for token
    echo ""
    read -rsp "  Paste $name token (hidden): " token
    echo ""

    [[ -n "$token" ]] || error $EX_USAGE "No token provided for $name."
    echo "$token"
}

set_org_secret() {
    local name="$1"
    local value="$2"

    note "Setting org secret $name..."
    echo "$value" | gh secret set "$name" --org "$org" --visibility all
    success "$name set on $org organization"
}

###########
# Main
###########

echo ""
echo "  ${b}NobleFactor Organization Secrets${n}"
echo ""
echo "  This script rotates two organization-wide secrets:"
echo ""
echo "    ${b}$automation_secret${n}"
echo "      Write access for cross-repo automation"
echo "      Required repos: $site_repo, $registry_repo, $ops_repo"
echo "      Permissions: Contents (RW), Pull requests (RW)"
echo ""
echo "    ${b}$content_secret${n}"
echo "      Read access for release workflows"
echo "      Required repos: All NobleFactor repos (read-only)"
echo "      Permissions: Contents (R), Metadata (R)"
echo ""

# Check for existing secrets
if gh secret list --org "$org" 2>/dev/null | grep -q "$automation_secret"; then
    note "Existing $automation_secret found — this will replace it."
fi
if gh secret list --org "$org" 2>/dev/null | grep -q "$content_secret"; then
    note "Existing $content_secret found — this will replace it."
fi

# Open browser
if [[ "$no_browser" == false ]]; then
    echo ""
    read -rp "  Open GitHub PAT page in browser? [Y/n] " open_browser
    if [[ "${open_browser:-Y}" =~ ^[Yy]?$ ]]; then
        if command -v open >/dev/null 2>&1; then
            open "$pat_url"
        elif command -v xdg-open >/dev/null 2>&1; then
            xdg-open "$pat_url"
        else
            note "Open manually: $pat_url"
        fi
    fi
fi

# Collect and validate NOBLEFACTOR_AUTOMATION
echo ""
echo "  ${b}1. $automation_secret${n}"
automation_token=$(prompt_token "$automation_secret" "NOBLEFACTOR_AUTOMATION")

note "Validating $automation_secret..."
validate_token "$automation_token" "$site_repo" "write"
success "Can access $site_repo"
validate_token "$automation_token" "$registry_repo" "write"
success "Can access $registry_repo"
validate_token "$automation_token" "$ops_repo" "read"
success "Can access $ops_repo"

# Collect and validate NOBLEFACTOR_CONTENT_ACCESS
echo ""
echo "  ${b}2. $content_secret${n}"
content_token=$(prompt_token "$content_secret" "NOBLEFACTOR_CONTENT_ACCESS")

note "Validating $content_secret..."
validate_token "$content_token" "$site_repo" "read"
success "Can access $site_repo"

# Set secrets
echo ""
set_org_secret "$automation_secret" "$automation_token"
set_org_secret "$content_secret" "$content_token"

echo ""
success "All secrets updated successfully."
echo ""
echo "  Workflows using these secrets will pick up the new values on next run."
echo "  Run this script again before the tokens expire (check GitHub for expiration dates)."
echo ""
