#!/usr/bin/env bash

# SPDX-License-Identifier: SSPL-1.0
# Copyright (c) 2025 Noble Factor. All rights reserved.

# Update-SiteDeployToken - Create or rotate the SITE_DEPLOY_TOKEN repository secret

# shellcheck disable=SC1091,SC2154
source "$(dirname "$0")/Declare-BashScript" "$0" "help,no-browser" "h" "$@"

command -v gh >/dev/null 2>&1 || error $EX_UNAVAILABLE "The 'gh' command is required. Install: https://cli.github.com"
command -v curl >/dev/null 2>&1 || error $EX_UNAVAILABLE "The 'curl' command is required."
gh auth status >/dev/null 2>&1 || error $EX_CONFIG "Not authenticated with gh. Run: gh auth login"

###########
# Variables
###########

declare -r cli_repo="NobleFactor/devlore-cli"
declare -r site_repo="NobleFactor/devlore.noblefactor.com"
declare -r secret_name="SITE_DEPLOY_TOKEN"
declare -r pat_url="https://github.com/settings/personal-access-tokens/new"

###########
# Arguments
###########

declare -r synopsis="Update-SiteDeployToken [--no-browser]"
eval set -- "$script_arguments"

no_browser=false

while :; do
    case "$1" in
        -h | --help)
            usage "$synopsis"
            ;;
        --no-browser)
            no_browser=true
            shift 1
            ;;
        --)
            shift 1
            break
            ;;
        *)
            break
            ;;
    esac
done

###########
# Main
###########

# Check for existing secret

if gh secret list --repo "$cli_repo" 2>/dev/null | grep -q "$secret_name"; then
    note "Existing $secret_name secret found — this will replace it."
fi

# Instructions

echo ""
echo "  Create a fine-grained Personal Access Token with these settings:"
echo ""
echo "    Repository access: Only select repositories → ${b}${site_repo}${n}"
echo ""
echo "    Permissions:"
echo "      Contents:       ${b}Read and write${n}"
echo "      Pull requests:  ${b}Read and write${n}"
echo ""
echo "    Expiration:  90 days (recommended)"
echo "    Token name:  devlore-cli-docs-publish"
echo ""

# Open browser

if [[ "$no_browser" == false ]]; then
    read -rp "  Open GitHub in browser? [Y/n] " open_browser
    if [[ "${open_browser:-Y}" =~ ^[Yy]?$ ]]; then
        if command -v open >/dev/null 2>&1; then
            open "$pat_url"
        elif command -v xdg-open >/dev/null 2>&1; then
            xdg-open "$pat_url"
        else
            note "Open manually: $pat_url"
        fi
    fi
fi

# Read token

echo ""
read -rsp "  Paste token (hidden): " token
echo ""

[[ -n "$token" ]] || error $EX_USAGE "No token provided."

# Validate token

note "Validating token..."

http_code=$(curl -s -o /dev/null -w "%{http_code}" \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/vnd.github+json" \
    "https://api.github.com/repos/$site_repo")

case "$http_code" in
    200) success "Token can access $site_repo" ;;
    401) error $EX_NOPERM "Token is invalid (401 Unauthorized)" ;;
    403) error $EX_NOPERM "Token lacks access to $site_repo (403 Forbidden)" ;;
    404) error $EX_NOPERM "Token cannot see $site_repo (404 — check repository permissions)" ;;
    *) error $EX_PROTOCOL "Unexpected response: HTTP $http_code" ;;
esac

contents_check=$(curl -s -o /dev/null -w "%{http_code}" \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/vnd.github+json" \
    "https://api.github.com/repos/$site_repo/contents/README.md")

if [[ "$contents_check" == "200" ]]; then
    success "Token can read repository contents"
else
    note "Could not verify contents access (HTTP $contents_check)"
fi

# Set secret

note "Setting repository secret..."
echo "$token" | gh secret set "$secret_name" --repo "$cli_repo"
success "$secret_name set on $cli_repo"

echo ""
echo "  The docs-publish workflow will use this token on next push to develop/release*/main."
echo "  Run this script again before the token expires."
